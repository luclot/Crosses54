#include <behaviors.dtsi>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

/ {
    chosen { zmk,physical-layout = &gggw_crosses_54_layout; };

    combos {
        compatible = "zmk,combos";

        Combo1 {
            bindings = <&kp LEFT_WIN>;
            key-positions = <50 49>;
        };

        Combo2 {
            bindings = <&tog 3>;
            key-positions = <49 48>;
        };

        Combo3 {
            bindings = <&kp RIGHT_ALT>;
            key-positions = <51 52>;
        };

        Combo4 {
            bindings = <&tog 1>;
            key-positions = <52 53>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
&kp TILDE    &kp N1  &kp N2  &kp N3                    &kp N4         &kp N5     &kp N6     &kp N7   &kp N8                    &kp N9         &kp N0      &kp LEFT_BRACKET
&kp TAB      &kp B   &kp L   &kp D                     &kp C          &kp V      &kp J      &kp F    &kp O                     &kp U          &kp COMMA   &kp RIGHT_BRACKET
&kp MINUS    &kp N   &kp R   &kp T                     &kp S          &kp G      &kp Y      &kp H    &kp A                     &kp E          &kp I       &kp SLASH
&lt 2 EQUAL  &kp X   &kp Q   &kp M                     &kp W          &kp Z      &kp K      &kp P    &kp SQT                   &kp SEMICOLON  &kp PERIOD  &lt 2 BACKSLASH
                             &mt RIGHT_CONTROL ESCAPE  &kp BACKSPACE  &kp ENTER  &kp SPACE  &kp DEL  &mt RIGHT_SHIFT CAPSLOCK
            >;
        };

        lower_layer {
            display-name = "Lower";
            bindings = <
&kp LC(LS(ESCAPE))  &kp LG(I)           &kp LG(PERIOD)      &kp LG(E)       &kp LG(LS(S))        &kp LG(PRINTSCREEN)  &kp CARET  &kp NUMBER_7  &kp N8        &kp N9        &kp MINUS     &kp LEFT_PARENTHESIS
&kp HOME            &kp LC(UP_ARROW)    &kp LC(LEFT_ARROW)  &kp UP_ARROW    &kp LC(RIGHT_ARROW)  &kp PAGE_UP          &none      &kp NUMBER_4  &kp N5        &kp NUMBER_6  &kp PLUS      &kp RIGHT_PARENTHESIS
&kp END             &kp LC(DOWN_ARROW)  &kp LEFT_ARROW      &kp DOWN_ARROW  &kp RIGHT_ARROW      &kp PAGE_DOWN        &kp EQUAL  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp SLASH     &kp SQT
&kp LC(Y)           &kp LC(Z)           &kp LC(X)           &kp LC(C)       &kp LC(V)            &kp LC(A)            &kp COMMA  &kp N0        &kp N0        &kp PERIOD    &kp ASTERISK  &kp DOUBLE_QUOTES
                                                            &trans          &trans               &trans               &trans     &trans        &trans
            >;
        };

        raise_layer {
            display-name = "Raise";
            bindings = <
&kp F1            &kp F2             &kp F3              &kp F4           &kp F5           &kp F6           &kp F7      &kp F8           &kp F9      &kp F10          &kp F11         &kp F12
&kp C_MUTE        &kp C_VOLUME_DOWN  &kp C_VOLUME_UP     &bl BL_TOG       &bl BL_DEC       &bl BL_INC       &none       &none            &none       &none            &none           &none
&kp C_PLAY_PAUSE  &kp C_REWIND       &kp C_FAST_FORWARD  &rgb_ug RGB_TOG  &rgb_ug RGB_HUD  &rgb_ug RGB_HUI  &kp SYSREQ  &kp PRINTSCREEN  &kp INSERT  &kp PAUSE_BREAK  &kp KP_NUMLOCK  &kp SCROLLLOCK
&trans            &trans             &trans              &rgb_ug RGB_EFF  &rgb_ug RGB_SAI  &rgb_ug RGB_SAD  &none       &none            &none       &none            &none           &none
                                                         &trans           &trans           &trans           &trans      &trans           &trans
            >;
        };

        mouse_layer {
            display-name = "Mouse";
            bindings = <
&studio_unlock  &trans  &trans          &trans          &trans           &trans  &mkp LCLK  &mkp MCLK       &mkp RCLK       &trans           &trans  &studio_unlock
&trans          &trans  &trans          &msc SCRL_UP    &trans           &trans  &trans     &trans          &mmv MOVE_UP    &trans           &trans  &trans
&trans          &trans  &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_RIGHT  &trans  &trans     &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &trans  &trans
&trans          &trans  &trans          &trans          &trans           &trans  &mkp LCLK  &mkp MCLK       &mkp RCLK       &trans           &trans  &trans
                                        &trans          &trans           &trans  &mkp LCLK  &mkp MCLK       &mkp RCLK
            >;
        };
    };
};
